# =====================================================
# BillFlow Backend — Environment Variables
# Copy to .env and fill in your values
# =====================================================

# App
APP_NAME=BillFlow
APP_ENV=development
DEBUG=True

# Security
SECRET_KEY=your-secret-key-min-32-chars-change-me
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Supabase PostgreSQL (Transaction Pooler URL)
DATABASE_URL=postgresql+asyncpg://postgres.YOURREF:YOURPASS@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Supabase
SUPABASE_URL=https://YOURREF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# Super Admin email (this exact email gets super_admin role on first login)
SUPER_ADMIN_EMAIL=admin@billflow.io

# PDF
PDF_ENGINE=reportlab

# ── SMTP for OTP emails ───────────────────────────────────
# Option A: Gmail App Password
#   1. Enable 2FA on Gmail
#   2. Go to myaccount.google.com/apppasswords
#   3. Generate a password for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_EMAIL=your-gmail@gmail.com
SMTP_USE_TLS=True

# Option B: Supabase SMTP (Project Settings > Auth > SMTP)
# SMTP_HOST=mail.supabase.io
# SMTP_PORT=587
# SMTP_USERNAME=...
# SMTP_PASSWORD=...
# SMTP_FROM_EMAIL=noreply@yourdomain.com

# Note: If SMTP is not configured, OTPs are printed in backend logs (dev mode)
