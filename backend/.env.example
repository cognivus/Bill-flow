# =====================================================
# BillFlow Backend — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env
# =====================================================

# App
APP_NAME=BillFlow
APP_ENV=development
DEBUG=True

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-min-32-chars
JWT_SECRET_KEY=change-me-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# Supabase PostgreSQL (use Transaction Pooler URL from Supabase Dashboard)
DATABASE_URL=postgresql+asyncpg://postgres.YOURREF:YOURPASS@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Supabase (Project Settings > API)
SUPABASE_URL=https://YOURREF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# CORS — add your frontend domain
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# Super Admin — this email gets super_admin role on first signup
SUPER_ADMIN_EMAIL=admin@billflow.io

# PDF
PDF_ENGINE=reportlab

# ── SMTP for OTP Emails ───────────────────────────────────────────────────────
#
# If SMTP is NOT configured:
#   → OTP is printed in backend logs AND returned in the signup API response
#   → The frontend shows it on screen (dev mode banner)
#   → This is fine for development; configure SMTP before going to production
#
# ── Option A: Gmail (recommended for quick setup) ────────────────────────────
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail" / "Other"
#   4. Use that 16-character password below (NOT your regular Gmail password)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx    # 16-char App Password (spaces OK)
SMTP_FROM_EMAIL=your-gmail@gmail.com
SMTP_USE_TLS=True

# ── Option B: Resend (https://resend.com — free tier: 100 emails/day) ────────
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USERNAME=resend
# SMTP_PASSWORD=re_xxxxxxxxxxxx       # Resend API key
# SMTP_FROM_EMAIL=onboarding@resend.dev
# SMTP_USE_TLS=True

# ── Option C: Supabase SMTP (Project Settings > Auth > SMTP Settings) ────────
# SMTP_HOST=mail.supabase.io
# SMTP_PORT=587
# SMTP_USERNAME=your-supabase-smtp-username
# SMTP_PASSWORD=your-supabase-smtp-password
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_USE_TLS=True

# ── Option D: Brevo / SendGrid / Mailgun — use their SMTP credentials ────────
