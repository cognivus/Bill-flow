# =====================================================
# BillFlow Backend — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# =====================================================

APP_NAME=BillFlow
APP_ENV=development
DEBUG=True

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-min-32-chars
JWT_SECRET_KEY=change-me-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database (Supabase → Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql+asyncpg://postgres.YOURREF:YOURPASS@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOURREF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# Super Admin — this email gets super_admin role on first signup
SUPER_ADMIN_EMAIL=admin@billflow.io

# ── Email via Resend (REQUIRED for OTP delivery on Render) ───────────────────
#
# WHY NOT SMTP?
#   Render's free tier blocks all outbound SMTP ports (25, 465, 587).
#   Gmail App Passwords won't work. Use Resend's HTTPS API instead.
#
# SETUP (free, takes 2 minutes):
#   1. Go to https://resend.com → Sign up (free)
#   2. Click "API Keys" → "Create API Key"
#   3. Copy the key (starts with re_) and paste below
#   4. Add this key in Render: Environment → RESEND_API_KEY
#
# FROM EMAIL:
#   - Without a custom domain: use "onboarding@resend.dev" (works instantly)
#   - With your own domain: verify it in Resend → Domains, then use noreply@yourdomain.com
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# PDF
PDF_ENGINE=reportlab
